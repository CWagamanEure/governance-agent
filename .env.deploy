DAO_SPACE_PUBLIC=arbitrumfoundation.eth
POLICY_ENGINE_VERSION_PUBLIC=0.2.2-preview
GIT_COMMIT_PUBLIC=66a12671d7c7a64084479444c9cb9ba7db13599d
EIGEN_APP_ID_PUBLIC=0xc9645B5C0A942e4dE16525513FE36D48DA7D911d
LLM_PROVIDER=auto
# Sepolia EigenCompute apps should use the dev gateway. Mainnet EigenCompute
# apps should use https://ai-gateway.eigencloud.xyz instead.
EIGEN_GATEWAY_URL=https://ai-gateway.eigencloud.xyz
# Fallback DAOs scanned by SignAndVerifyCard + AutopilotRunCard when the
# primary DAO has no active proposals. Each must also be on the submit
# allowlist; getSubmitAllowlist() unions DAO_SPACE_PUBLIC + this list.
SNAPSHOT_FALLBACK_SPACES_PUBLIC=gitcoindao.eth,gnosis.eth,kleros.eth
