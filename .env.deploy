DAO_SPACE_PUBLIC=arbitrumfoundation.eth
POLICY_ENGINE_VERSION_PUBLIC=0.2.2-preview
GIT_COMMIT_PUBLIC=b4cd23fccb7dcdd16eb252f247228d14eb0f1807
EIGEN_APP_ID_PUBLIC=0xc9645B5C0A942e4dE16525513FE36D48DA7D911d
LLM_PROVIDER=auto
# Sepolia EigenCompute apps should use the dev gateway. Mainnet EigenCompute
# apps should use https://ai-gateway.eigencloud.xyz instead.
EIGEN_GATEWAY_URL=https://ai-gateway.eigencloud.xyz
# Fallback DAOs autopilot + Trust tab scan when the primary DAO has no
# active proposals. Each must also be on the submit allowlist;
# getSubmitAllowlist() unions DAO_SPACE_PUBLIC + this list.
SNAPSHOT_FALLBACK_SPACES_PUBLIC=gitcoindao.eth,gnosis.eth,kleros.eth,lido-snapshot.eth
# OPERATOR_ADDRESS_ALLOWLIST: when set (comma-separated 0x addresses),
# only listed wallets can SIWE-verify. Currently unset for public-demo
# access — rate-limit + per-batch live-extraction budget are the
# defenses. Set this before any production deploy.
# AUTOPILOT_POLL_ENABLED: when "true", the background cron polls every
# AUTOPILOT_POLL_INTERVAL_MS (default 15 min) and autopilot-votes on
# behalf of every user with autopilot enabled in their saved policy.
# Currently OFF for the demo so cron timing does not collide with the
# narration.
