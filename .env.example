# Public env vars (visible to users on EigenCompute — use _PUBLIC suffix).
# These are part of the trust surface: users can verify which DAO and policy
# version a deployed instance is configured for.
DAO_SPACE_PUBLIC=arbitrumfoundation.eth
POLICY_ENGINE_VERSION_PUBLIC=0.1.0-helloworld
GIT_COMMIT_PUBLIC=unknown

# LLM auth — pick ONE path. The model picker in src/llm.ts prefers the Eigen
# proxy if KMS_AUTH_JWT is present, else falls back to Anthropic direct.
#
# (A) In-enclave on EigenCompute: KMS_AUTH_JWT is auto-injected at runtime.
#     Inference is covered by your $500 EigenPreview credit. Nothing to set.
#
# (B) Local dev (no JWT available): set your own Anthropic key. Costs come
#     out of your console.anthropic.com balance.
ANTHROPIC_API_KEY=

# Auto-injected by EigenCompute at deploy time.
# For LOCAL dev only, set a throwaway 12-word BIP-39 mnemonic (quoted).
# The value below is the well-known Hardhat/Foundry default — known insecure,
# safe for local testing only.
MNEMONIC="test test test test test test test test test test test junk"
